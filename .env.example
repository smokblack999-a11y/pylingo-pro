# ── REQUIRED ───────────────────────────────────────────────────────
# Сгенерируй свой ключ на https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-

# Случайная строка минимум 32 символа
JWT_SECRET=samurai_secret_CHANGE_TO_RANDOM_32_chars_minimum

# Пароль для админа
ADMIN_PASSWORD=admin123

# ── TELEGRAM ───────────────────────────────────────────────────────
# Создай бота через @BotFather
BOT_TOKEN=

# Твой Telegram ID (узнай через @userinfobot)
ADMIN_TG_ID=

# ── PORTS ─────────────────────────────────────────────────────────
API_PORT=3000

# ── REDIS ─────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── RATE LIMITING ─────────────────────────────────────────────────
RATE_LIMIT_MS=2000

# ── AI MODELS ────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=2000
